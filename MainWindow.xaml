<Window x:Class="Surprise_Attack_test.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Surprise_Attack_test"
        mc:Ignorable="d" 
        Title="Suprise Attack" Height="811" Width="1390">
    <Grid>

        <Grid.ColumnDefinitions>

            <ColumnDefinition Width="4*" />
            <ColumnDefinition Width="250"/>

        </Grid.ColumnDefinitions>

        <Image x:Name="MapImage"
               Grid.Column="0"
               Stretch="Uniform"           
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               MouseLeftButtonDown="MapImage_MouseLeftButtonDown"
               />

        <StackPanel Grid.Column="1" Background="BlanchedAlmond">

            <Label Content="Settings" FontSize="20" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            <Label Content="Generation Count: 0" FontSize="15" HorizontalAlignment="Left" Margin="20,20,10,0" Name="GenCount_Label"/>
            <TextBox x:Name="GenCountBox" Height="25" Width="40" HorizontalAlignment="Left" VerticalContentAlignment="Center" Margin="20,5,15,0" Text="20"/>
            <CheckBox x:Name="chkShowRestricted"  Content="Show Restricted Areas" FontSize="14" Margin="20,10" Checked="RestrictedArea_Checked" Unchecked="RestrictedArea_Unchecked"/>
            <Button Name="AddCamera_Button" Content="Add Camera" Margin="20,20" Height="40" Click="AddCamera_Click"/>
            <Button Name="DeleteCamera_Button" Content="Delete Camera" Margin="20,20" Height="40" Click="DeleteCamera_Click"/>
            <Button Name="AddMountain_Button" Content="Add Mountain" Margin="20,20" Height="40" Click="AddMountain_Click"/>
            <Button Name="ClearMap_Button" Content="Clear Map" Margin="20,20" Height="40" Click="ClearMap_Click"/>
            <Button Name="StartPos_Button" Content="Choose Starting Position" Margin="20,20" Height="40" Click="StartPos_Click"/>
            <Button Name="TargetPos_Button" Content="Choose Target Position" Margin="20,20" Height="40" Click="TargetPos_Click"/>
            <Button Name="StartSimulation_Button" Content="Start Simulation" Margin="20,20" Height="40" IsEnabled="False" Click="StartSimulation_Click"/>
            <Button Name="FastStartSimulation_Button" Content="Start No Delay Simulation" Margin="20,20" Height="40" IsEnabled="False" Click="FastStartSimulation_Click"/>
            <Button Name="BestAnt_Button" Content="Show Best Ant" Margin="20,20" Height="40" IsEnabled="False" Click="BestAnt_Click"/>


        </StackPanel>


        <Border Name="MountainInputOverlay" Background="White" Width="300" Height="250" CornerRadius="10" BorderBrush="Gray" BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
            </Border.Effect>

            <StackPanel Margin="20" VerticalAlignment="Center">
                <TextBlock Text="Add Mountain" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Radius:"/>
                    <TextBox Grid.Column="1" x:Name="txtOverlayRadius" Height="25" VerticalContentAlignment="Center" Text="6"/>
                </Grid>

                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Height:"/>
                    <TextBox Grid.Column="1" x:Name="txtOverlayHeight" Height="25" VerticalContentAlignment="Center" Text="220"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Cancel" Width="70" Height="25" Margin="0,0,10,0" Click="OverlayCancel_Click"/>
                    <Button Content="Confirm" Width="70" Height="25" FontWeight="Bold" Background="#DDFFDD" Click="OverlayConfirm_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    
    
</Window>
