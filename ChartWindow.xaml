<Window x:Class="Surprise_Attack_test.ChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        Title="Convergence Analytics" Height="450" Width="800" Background="#F7FAFC">

    <Grid Margin="20">
        <lvc:CartesianChart x:Name="ConvergenceGraphUI" 
                            Series="{Binding SeriesCollection}" 
                            Zoom="X" Pan="X" Background="Transparent">

            <lvc:CartesianChart.AxisX>
                <lvc:Axis Title="Generation" MinValue="1">
                    <lvc:Axis.Separator>
                        <lvc:Separator Step="5" />
                    </lvc:Axis.Separator>
                </lvc:Axis>
            </lvc:CartesianChart.AxisX>

            <lvc:CartesianChart.AxisY>
                <lvc:Axis Title="Best Distance" MaxValue="7000"  LabelFormatter="{Binding YFormatter}" />
            </lvc:CartesianChart.AxisY>
        </lvc:CartesianChart>
    </Grid>
</Window>